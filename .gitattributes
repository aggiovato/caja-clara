# Normalize line endings: store all text files with LF in the repo.
* text=auto eol=lf

# Shell scripts and the Gradle wrapper must always be LF.
*.sh    text eol=lf
gradlew text eol=lf

# Source and config files: LF.
*.kt        text eol=lf
*.kts       text eol=lf
*.java       text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.properties text eol=lf
*.md        text eol=lf
*.pro       text eol=lf

# Windows-only files stay CRLF.
*.bat       text eol=crlf
gradlew.bat text eol=crlf

# Binary files: never touch.
*.ttf   binary
*.otf   binary
*.png   binary
*.webp  binary
*.jpg   binary
*.jpeg  binary
*.apk   binary
*.jar   binary
*.keystore binary
*.aab   binary
